POSTGRES_USER=rappi
POSTGRES_PASSWORD=rappi
POSTGRES_DB=rappi_ops
POSTGRES_PORT=5432

OPS_API_PORT=8000
N8N_PORT=5678
WEB_APP_PORT=3000
TZ=America/Bogota

# Replace before sharing or deploying.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-value
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
