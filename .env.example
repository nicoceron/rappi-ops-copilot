POSTGRES_USER=rappi
POSTGRES_PASSWORD=
POSTGRES_DB=rappi_ops
POSTGRES_PORT=5432

OPS_API_PORT=8000
N8N_PORT=5678
WEB_APP_PORT=3000
TZ=America/Bogota

# Required. Generate local values with:
# openssl rand -base64 32
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Configure this inside n8n credentials, not in committed workflow JSON.
DEEPSEEK_API_KEY=

# Local embedded chat URL generated by the n8n Chat Trigger workflow.
NEXT_PUBLIC_OPS_API_URL=http://localhost:8000
NEXT_PUBLIC_N8N_CHAT_WEBHOOK_URL=http://localhost:5678/webhook/b2a0878f-58c7-4f89-a98b-2dc29cd637a8/chat
