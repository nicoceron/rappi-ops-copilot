POSTGRES_USER=rappi
POSTGRES_PASSWORD=
POSTGRES_DB=rappi_ops
POSTGRES_PORT=5432

OPS_API_PORT=8000
N8N_PORT=5678
WEB_APP_PORT=3000
TZ=America/Bogota

# Required. Generate local values with:
# openssl rand -base64 32
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Configure this inside n8n credentials, not in committed workflow JSON.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional extra context injected into the LLM narrative authoring prompt.
INSIGHTS_BUSINESS_CONTEXT=

# Used by the API when LaTeX PDF compilation fails during automatic insights.
LATEX_REPAIR_ATTEMPTS=2

# Local embedded chat URL generated by the n8n Chat Trigger workflow.
PUBLIC_API_BASE_URL=http://localhost:8000
N8N_INSIGHTS_WEBHOOK_URL=http://n8n:5678/webhook/rappi-ops-executive-insights/run
NEXT_PUBLIC_OPS_API_URL=http://localhost:8000
NEXT_PUBLIC_N8N_CHAT_WEBHOOK_URL=http://localhost:5678/webhook/b2a0878f-58c7-4f89-a98b-2dc29cd637a8/chat
